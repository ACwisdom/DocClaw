# LLM 配置（方案 A：OpenAI 兼容 API）
# 复制为 .env 后填入真实 Key：copy .env.example .env

# 智谱 GLM-5.1（推荐）
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-glm-api-key
LLM_MODEL=glm-5.1
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_FALLBACK_TO_MOCK=true
LLM_DISABLE_THINKING=true

# 其他兼容端点示例：
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
# 通义千问: LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1  LLM_MODEL=deepseek-chat

# ---------- DeepAgents Harness（Phase 0+）----------
# 可与上方 LLM_* 共用同一 Key；DeepSeek 专用变量优先
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MongoDB（HITL interrupt/resume 必需；未安装时自动回退 MemorySaver）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=doctorclaw_agent
MONGODB_CHECKPOINT_COLLECTION=checkpoints

# Harness 服务
MEDICAL_API_BASE_URL=http://localhost:8000/api
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_PATH=/mcp
AGENT_API_PORT=8090

# OpenSandbox（Phase 4 前留空，使用本地 FilesystemBackend 降级）
SANDBOX_DOMAIN=
